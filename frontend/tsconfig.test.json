{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "types": [
      "vite/client",
      "vitest/globals",
      "@testing-library/jest-dom",
      "node"
    ],
    "allowImportingTsExtensions": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "verbatimModuleSyntax": false,
    "erasableSyntaxOnly": false,
    "moduleDetection": "auto"
  },
  "include": ["src", "tests"]
}
